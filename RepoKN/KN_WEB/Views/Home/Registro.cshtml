@model KN_WEB.Models.UsuarioModel

@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="row h-100">
    <div class="col-lg-5 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a href="@Url.Action("Index","Home")"><img src="~/Content/images/logo.png" alt="Logo"></a>
            </div>

            <h1 class="auth-title">Registrar Usuarios</h1>

            @using (Html.BeginForm("Registro", "Home", FormMethod.Post, new { @id = "RegistroForm" }))
            {

                if (ViewBag.Mensaje != null)
                {
                    <div class="alert text-danger" role="alert">
                        @ViewBag.Mensaje
                    </div>
                }

                <div class="form-group position-relative has-icon-left">
                    @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control form-control-xl", @placeholder = "Identificación" })
                    <div class="form-control-icon">
                        <i class="bi bi-person-badge"></i>
                    </div>
                </div>

                <div class="form-group position-relative has-icon-left">
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control form-control-xl", @placeholder = "Nombre" })
                    <div class="form-control-icon">
                        <i class="bi bi-person"></i>
                    </div>
                </div>

                <div class="form-group position-relative has-icon-left">
                    @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control form-control-xl", @placeholder = "Correo Electrónico" })
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>

                <div class="form-group position-relative has-icon-left">
                    @Html.TextBoxFor(m => m.Contrasenna, new { @type = "password", @class = "form-control form-control-xl", @placeholder = "Contraseña" })
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-3">Procesar</button>
            }

            <div class="text-center mt-5 text-lg fs-4">
                <p class='text-gray-600'>
                    ¿Ya tiene una cuenta? <a href="@Url.Action("Index","Home")" class="font-bold">
                        Inicie Sesión
                    </a>
                </p>
            </div>
        </div>
    </div>
    <div class="col-lg-7 d-none d-lg-block">
        <div id="auth-right">

        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/registro.js"></script>
}