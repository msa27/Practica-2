@model Practica2.Web.Models.ClienteModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-title">
    <div class="row">
        <div class="col-12 col-md-6 order-md-1 order-last">
            <h3>Registro de Clientes</h3>
        </div>
    </div>
</div>
<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title">Datos del cliente</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Registrar", "Clientes", FormMethod.Post, new { @id = "RegistrarClienteForm", accept_charset = "utf-8" }))
            {
                if (ViewBag.Mensaje != null)
                {
                    <div class="alert text-danger" role="alert">@ViewBag.Mensaje</div>
                }

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Cedula, new { @class = "form-control form-control-xl", @placeholder = "Cédula" })
                    <div class="form-control-icon"><i class="bi bi-person-badge"></i></div>
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control form-control-xl", @placeholder = "Nombre" })
                    <div class="form-control-icon"><i class="bi bi-person"></i></div>
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control form-control-xl", @placeholder = "Correo" })
                    <div class="form-control-icon"><i class="bi bi-envelope"></i></div>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-3">Procesar</button>
            }
        </div>
    </div>
</section>

@section scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/registrar-cliente.js"></script>
}
