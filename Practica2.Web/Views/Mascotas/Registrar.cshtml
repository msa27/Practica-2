@model Practica2.Web.Models.MascotaModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-title">
    <div class="row">
        <div class="col-12 col-md-6 order-md-1 order-last">
            <h3>Registro de Mascotas</h3>
        </div>
    </div>
</div>
<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title">Datos de la mascota</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Registrar", "Mascotas", FormMethod.Post, new { @id = "RegistrarMascotaForm" }))
            {
                if (ViewBag.Mensaje != null)
                {
                    <div class="alert text-danger" role="alert">@ViewBag.Mensaje</div>
                }

                <div class="form-group mb-3">
                    @Html.DropDownListFor(m => m.IdCliente, Model.Clientes, new { @class = "form-select form-control-xl" })
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control form-control-xl", @placeholder = "Nombre" })
                    <div class="form-control-icon"><i class="bi bi-heart"></i></div>
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Especie, new { @class = "form-control form-control-xl", @placeholder = "Especie" })
                    <div class="form-control-icon"><i class="bi bi-tag"></i></div>
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Raza, new { @class = "form-control form-control-xl", @placeholder = "Raza" })
                    <div class="form-control-icon"><i class="bi bi-bookmark"></i></div>
                </div>

                <div class="form-group position-relative has-icon-left mb-3">
                    @Html.TextBoxFor(m => m.Peso, new { @class = "form-control form-control-xl", @placeholder = "Peso", @type = "number", @step = "0.01", @min = "0.01" })
                    <div class="form-control-icon"><i class="bi bi-speedometer2"></i></div>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-3">Procesar</button>
            }
        </div>
    </div>
</section>

@section scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
    <script src="~/Scripts/registrar-mascota.js"></script>
}
