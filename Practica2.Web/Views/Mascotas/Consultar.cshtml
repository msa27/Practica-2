@model IEnumerable<Practica2.Web.Models.ConsultaMascotaModel>
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-title">
    <div class="row">
        <div class="col-12 col-md-6 order-md-1 order-last">
            <h3>Consulta de Mascotas</h3>
        </div>
    </div>
</div>
<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title">Listado de mascotas registradas</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Cédula Cliente</th>
                            <th>Nombre Cliente</th>
                            <th>Nombre Mascota</th>
                            <th>Especie</th>
                            <th>Peso</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.CedulaCliente</td>
                                    <td>@item.NombreCliente</td>
                                    <td>@item.NombreMascota</td>
                                    <td>@item.Especie</td>
                                    <td>@item.Peso.ToString("0.00")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No hay mascotas registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
