<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Práctica 2 - Clientes y Mascotas</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/perfect-scrollbar.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Content/app.css">
</head>
<body>
    <div id="app">
        <div id="sidebar" class="active">
            <div class="sidebar-wrapper active">
                <div class="sidebar-header">
                    <div class="d-flex justify-content-between">
                        <div class="logo">
                            <a href="@Url.Action("Index", "Home")"><img src="~/Content/images/logo.png" alt="Logo"></a>
                        </div>
                        <div class="toggler">
                            <a href="#" class="sidebar-hide d-xl-none d-block"><i class="bi bi-x bi-middle"></i></a>
                        </div>
                    </div>
                </div>
                <div class="sidebar-menu">
                    <ul class="menu">
                        <li class="sidebar-title">Menú</li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("Registrar", "Clientes")" class="sidebar-link">
                                <i class="bi bi-person-plus-fill"></i>
                                <span>Registro de Clientes</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("Registrar", "Mascotas")" class="sidebar-link">
                                <i class="bi bi-heart-fill"></i>
                                <span>Registro de Mascotas</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("Consultar", "Mascotas")" class="sidebar-link">
                                <i class="bi bi-search"></i>
                                <span>Consulta de Mascotas</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <button class="sidebar-toggler btn x"><i class="bi bi-x"></i></button>
            </div>
        </div>
        <div id="main">
            <header class="mb-3">
                <nav class="navbar navbar-expand navbar-header">
                    <a href="#" class="burger-btn d-block d-xl-none">
                        <i class="bi bi-justify fs-3"></i>
                    </a>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <span class="nav-link text-muted fw-semibold">Bienvenido al sistema de gestión de mascotas</span>
                            </li>
                        </ul>
                    </div>
                </nav>
            </header>
            <div class="page-heading">
                @RenderBody()
            </div>
            <footer>
                <div class="footer clearfix mb-0 text-muted">
                    <div class="float-start">
                        <p>@DateTime.Now.Year &copy; Práctica 2</p>
                    </div>
                    <div class="float-end">
                        <p>Clientes y Mascotas</p>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    <script src="~/Scripts/perfect-scrollbar.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/main.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
